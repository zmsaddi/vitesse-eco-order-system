{
  "name": "vitesse-eco",
  "version": "0.1.0",
  "private": true,
  "description": "VITESSE ECO SAS — نظام إدارة الطلبات والعمليات (Order & Operations Management System)",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --coverage",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:authz": "vitest run tests/authz --passWithNoTests",
    "test:regression": "vitest run tests/regression --passWithNoTests",
    "test:money:edge": "vitest run tests/money --passWithNoTests",
    "test:auth:full": "vitest run tests/auth --passWithNoTests",
    "test:e2e:smoke": "node scripts/placeholder.mjs",
    "test:perf": "node scripts/placeholder.mjs",
    "test:a11y": "node scripts/placeholder.mjs",
    "test:logs": "node scripts/placeholder.mjs",
    "test:responsive": "node scripts/placeholder.mjs",
    "test:keyboard": "node scripts/placeholder.mjs",
    "test:voice:accuracy": "node scripts/placeholder.mjs",
    "test:perf:compare-baseline": "node scripts/placeholder.mjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:check": "drizzle-kit check",
    "db:migrate:round-trip": "node scripts/placeholder.mjs",
    "openapi:drift": "node scripts/placeholder.mjs",
    "openapi:diff": "node scripts/placeholder.mjs"
